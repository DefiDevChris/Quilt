# ============================================================
# QuiltCorgi Environment Configuration
# ============================================================
#
# HOW SECRETS WORK:
#
# Production:
#   All secrets below (except NEXT_PUBLIC_*) are stored in AWS Secrets Manager
#   under the secret name "quiltcorgi/prod" (KMS-encrypted).
#   instrumentation.ts loads them at startup and injects into process.env.
#   Do NOT set these as plain environment variables in production.
#
# Local dev:
#   Set AWS_SECRET_NAME=skip to bypass Secrets Manager entirely.
#   All values are read directly from this file (.env.local).
#
# Build-time only (NEXT_PUBLIC_*):
#   These must be set in the deployment environment at build time.
#   They cannot come from Secrets Manager (loaded after build).
# ============================================================

# --- Secrets Manager control ---
# Set to "skip" for local dev. Defaults to "quiltcorgi/prod" in production.
AWS_SECRET_NAME=skip

# ============================================================
# Everything below is loaded from Secrets Manager in production.
# In local dev, set real values here.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://quiltcorgi:localdev@localhost:5432/quiltcorgi

# --- AWS Cognito ---
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-app-client-id
COGNITO_REGION=us-east-1

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRO_PRICE_MONTHLY=price_REPLACE_ME
STRIPE_PRO_PRICE_YEARLY=price_REPLACE_ME

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=quiltcorgi-uploads-dev

# --- Rate Limiting (optional in dev, required in production) ---
# Upstash Redis for distributed rate limiting across instances.
# Without this, rate limiting falls back to in-memory (single-process only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Build-time variables — set in deployment environment, NOT Secrets Manager.
# Must be present when `next build` runs.
# ============================================================
NEXT_PUBLIC_CLOUDFRONT_URL=https://your-distribution.cloudfront.net
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=QuiltCorgi
