# ============================================================
# QuiltCorgi Environment Configuration
# ============================================================
# Secrets are loaded from AWS Secrets Manager at runtime.
# Set AWS_SECRET_NAME=skip to use these env vars directly (dev mode).
# NEXT_PUBLIC_* vars must always be set here (needed at build time).
# ============================================================

# --- Secrets Manager ---
# AWS_SECRET_NAME=quiltcorgi/prod  (default; set "skip" to use .env only)

# --- Database (stored in Secrets Manager for production) ---
DATABASE_URL=postgresql://quiltcorgi:localdev@localhost:5432/quiltcorgi

# --- AWS Cognito (stored in Secrets Manager for production) ---
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-app-client-id
COGNITO_REGION=us-east-1

# --- Stripe (stored in Secrets Manager for production) ---
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRO_PRICE_ID=price_

# --- AWS S3 (stored in Secrets Manager for production) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=quiltcorgi-uploads-dev

# --- Public (required at build time — NOT in Secrets Manager) ---
NEXT_PUBLIC_CLOUDFRONT_URL=https://your-distribution.cloudfront.net
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
