{
  "mcpServers": {
    "chrome-devtools-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "env": {}
    },
    "mem-palace": {
      "command": "python3.12",
      "args": [
        "-m",
        "mempalace.mcp_server"
      ],
      "env": {
        "MEMPAL_DIR": "/home/chrishoran/Desktop/Quilt"
      }
    },
    "browseros": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "http://127.0.0.1:9000/mcp"
      ]
    }
  }
}