{
  "name": "quiltcorgi",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "type-check": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:blog": "tsx src/db/seed/seed-blog.ts",
    "db:local:up": "docker compose up -d --wait",
    "db:local:down": "docker compose down"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "~3.1029.0",
    "@aws-sdk/client-s3": "~3.1029.0",
    "@aws-sdk/s3-request-presigner": "~3.1029.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "clipper-lib": "^6.4.2",
    "drizzle-orm": "~0.45.2",
    "fabric": "~7.2.0",
    "framer-motion": "^12.38.0",
    "heic2any": "^0.0.4",
    "isomorphic-dompurify": "^3.8.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "react": "~19.2.5",
    "react-dom": "~19.2.5",
    "stripe": "~22.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "~25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4"
  }
}